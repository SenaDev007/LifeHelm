# === LifeHelm Backend — Production Environment ===
# Copie ce fichier en .env et remplis avec tes vraies valeurs de production.

# === PostgreSQL (Neon) ===
# Garder la même URL que en dev (Neon gère le pooler serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neon.tech/LifeHelm?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neon.tech/LifeHelm?sslmode=require"

# === Server ===
PORT=3001
NODE_ENV=production
# Restreindre CORS à ton domaine mobile (ou * pour autoriser tout)
# Pour Flutter mobile: * (pas d'origine précise) ou l'URL de ton backend web si existant
CORS_ORIGIN=*

# === Auth — IMPORTANT: génère des secrets forts en production ===
# Génère avec: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_also_generate_a_different_one
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# === HELM AI ===
# z-ai-web-dev-sdk fonctionne sans clé (package local)
# Si tu veux utiliser Anthropic Claude à la place:
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_API_KEY=

# === FedaPay (paiements Mobile Money + carte) ===
# 1. Crée un compte sur https://fedapay.com
# 2. Récupère ta clé secrète (sandbox pour tester, live pour prod)
# 3. Sandbox: https://sandbox-api.fedapay.com/v1
#    Live:    https://api.fedapay.com/v1
FEDAPAY_SECRET_KEY=
FEDAPAY_BASE_URL=https://api.fedapay.com/v1

# === Optionnel: Redis (pour production à grande échelle) ===
# REDIS_URL=redis://localhost:6379

# === Optionnel: Sentry (monitoring d'erreurs) ===
# SENTRY_DSN=
